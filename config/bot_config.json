{
  "slug": "for-our-honeymoon",
  "bot_name": "내 챗봇",
  "preset": "custom",
  "description": "이탈리아 돌로미티, 동유럽 여행 계획 작성을 위해 만든 챗봇입니다.",
  "frontend": "streamlit",
  "model_name": "gpt-5-mini",
  "embedding_model": "text-embedding-3-small",
  "chunk_size": 900,
