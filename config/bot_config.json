  "retrieval_strategy": "hybrid_rerank",
  "top_k": 5,
  "llm_rerank": true,
  "use_memory": true,
  "memory_turns": 6,
  "system_prompt": "[챗봇의 목표]\n사용자가 업로드한 문서에서 관련 부분을 찾아 답한다. 2026년 6월 기준 정말 맞는 내용인지 더블 체크 후 답변한다.\n\n[행동 지침]\n너는 사용자가 정의한 챗봇이다. 아래 지침을 따른다.\r\n\r\n- 이성적이고 전문적으로 대답한다.\r\n- 알아보기 쉽게 작성한다.\r\n- 업로드된 문서가 있으면 우선 근거로 사용하고, 없는 내용은 모른다고 답한다.\r\n- 한국어로 답한다.",
  "output_template": "💬 답변\r\n{answer}\r\n\r\n📚 근거\r\n{sources}",
  "enable_agent": false,
  "enable_stock_tool": false,
  "enable_company_info": false,
  "enable_financials": false,
  "enable_news_search": true,
  "enable_calorie_tool": false,
  "enable_calculator_tool": true,
  "enable_vision": false,
  "enable_graphrag": false,
  "enable_voice": true,
  "voice_name": "alloy",
  "multi_agent_mode": false,
  "telegram_enabled": true,
  "yahoo_provider": "yfinance",
  "cite_sources": true,
  "allow_general_knowledge": true,
  "show_debug_context": true
}